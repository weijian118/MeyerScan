#include <windows.h>

// Keep this test resource file ASCII-only for the VS2015 resource compiler.
VS_VERSION_INFO VERSIONINFO
 FILEVERSION     0,1,2,0
 PRODUCTVERSION  0,1,2,0
 FILEFLAGSMASK   0x3fL
#ifdef _DEBUG
 FILEFLAGS       VS_FF_DEBUG
#else
 FILEFLAGS       0x0L
#endif
 FILEOS          VOS_NT_WINDOWS32
 FILETYPE        VFT_APP
 FILESUBTYPE     0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Hefei Meyer Optoelectronic Technology Co., Ltd."
            VALUE "LegalCopyright",   "Copyright (C) 2026 HEFEI MEYER"
            VALUE "FileDescription",  "MeyerScan UI Resources Test Host"
            VALUE "FileVersion",      "0.1.2"
            VALUE "InternalName",     "UIResourcesTest"
            VALUE "OriginalFilename", "UIResourcesTest.exe"
            VALUE "ProductName",      "MeyerScan Digital Dental Scanner"
            VALUE "ProductVersion",   "0.1.2"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
