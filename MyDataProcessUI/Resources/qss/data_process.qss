QWidget#MeyerScanDataProcessUIRoot {
    background: #111827;
    color: #ffffff;
}

QLabel {
    color: #e8eef3;
}

QLabel#DataProcessPanelTitle {
    font-weight: 600;
}

QPushButton {
    border: 1px solid #3b4a58;
    border-radius: 5px;
    background: #1f2937;
    color: #f8fafc;
    padding: 7px 12px;
}

QPushButton:hover {
    background: #2f3d4c;
}

QPushButton:checked {
    background: #007d68;
    border-color: #007d68;
}
