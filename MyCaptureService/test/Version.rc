#include <windows.h>

#define MEYER_FILE_VERSION 0,2,0,0
#define MEYER_FILE_VERSION_TEXT "0.2.0.0\0"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION MEYER_FILE_VERSION
 PRODUCTVERSION MEYER_FILE_VERSION
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "080404b0"
        BEGIN
            VALUE "CompanyName", "MeyerScan\0"
            VALUE "FileDescription", "MeyerScan Capture Service Test\0"
            VALUE "FileVersion", MEYER_FILE_VERSION_TEXT
            VALUE "InternalName", "CaptureServiceTest\0"
            VALUE "OriginalFilename", "CaptureServiceTest.exe\0"
            VALUE "ProductName", "MeyerScan\0"
            VALUE "ProductVersion", MEYER_FILE_VERSION_TEXT
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0804, 1200
    END
END
