{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "MSBuild: Build (Debug)",
            "type": "shell",
            "command": "C:/Program Files (x86)/MSBuild/14.0/Bin/MSBuild.exe",
            "args": [
                "${workspaceFolder}/MeyerScan_Database.sln",
                "/p:Configuration=Debug",
                "/p:Platform=x64",
                "/m",
                "/v:minimal"
            ],
            "group": {"kind": "build"},
            "problemMatcher": "$msCompile"
        },
        {
            "label": "MSBuild: Build (Release)",
            "type": "shell",
            "command": "C:/Program Files (x86)/MSBuild/14.0/Bin/MSBuild.exe",
            "args": [
                "${workspaceFolder}/MeyerScan_Database.sln",
                "/p:Configuration=Release",
                "/p:Platform=x64",
                "/m",
                "/v:minimal"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Run Test (Debug)",
            "type": "shell",
            "command": "${workspaceFolder}/bin/Debug/DatabaseTest.exe",
            "problemMatcher": [],
            "dependsOn": ["MSBuild: Build (Debug)"]
        }
    ]
}
